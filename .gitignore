# Built application files
*.apk
*.aab
*.ap_

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
.idea/caches
.idea/modules.xml
.idea/navEditor.xml
.idea/.name
.idea/compiler.xml
.idea/jarRepositories.xml
.idea/misc.xml

# Keystore files — NEVER commit these
*.jks
*.keystore

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Google Services (contains API keys — never commit)
google-services.json

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Thumbnails
._*

# Test outputs
test-results/

# Proguard
proguard/

# Kotlin
*.kotlin_module
